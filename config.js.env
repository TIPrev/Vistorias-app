// ============================================================
// CONFIGURAÇÃO DE AMBIENTE - FRONTEND
// ============================================================

(function() {
  'use strict';
  
  // Detectar ambiente
  const HOSTNAME = window.location.hostname;
  const PROTOCOL = window.location.protocol;
  
  let API_BASE_URL;
  
  if (HOSTNAME === 'localhost' || HOSTNAME === '127.0.0.1') {
    // Desenvolvimento local
    API_BASE_URL = 'http://localhost:5000';
  } else if (HOSTNAME.includes('firebaseapp.com') || HOSTNAME.includes('web.app')) {
    // Firebase Hosting em produção
    // Detectar URL do backend pela variável ou usar railway
    const backendDomain = window.__BACKEND_URL__ || '';
    if (backendDomain) {
      API_BASE_URL = `https://${backendDomain}`;
    } else {
      // Fallback: tentar usar Railway default
      API_BASE_URL = 'https://vistoria-backend-production.up.railway.app';
    }
  } else {
    // Outro ambiente
    API_BASE_URL = `${PROTOCOL}//localhost:5000`;
  }
  
  // Exportar configuração global
  window.AppConfig = {
    API_BASE_URL: API_BASE_URL,
    ASSISTENTE_URL: `${API_BASE_URL}/assistente/chat`,
    ENVIRONMENT: (HOSTNAME === 'localhost' || HOSTNAME === '127.0.0.1') ? 'development' : 'production'
  };
  
  console.log('🔧 AppConfig:', window.AppConfig);
})();
